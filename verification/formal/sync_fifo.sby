[tasks]
bmc
cover

[options]
bmc: mode bmc
bmc: depth 48
cover: mode cover
cover: depth 72

[engines]
smtbmc

[script]
# Yosys cwd is <taskdir>/src (e.g. formal/sync_fifo_bmc/src); repo RTL is three levels up.
read_verilog -sv -DFORMAL ../../../../src/sync_fifo.v
prep -top sync_fifo
async2sync
